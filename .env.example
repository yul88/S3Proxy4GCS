# =============================================================================
# S3Proxy4GCS — Environment Configuration Reference
# =============================================================================
# 使用方法：
#   cp .env.example .env
#   按需修改 .env 中的值，敏感字段（密钥、JSON 路径）不要提交到 Git。
#
# 所有字段均为可选，未设置时使用括号内的默认值。
# =============================================================================


# -----------------------------------------------------------------------------
# 核心代理配置
# -----------------------------------------------------------------------------

# 监听端口（默认 8080）
PORT=8080

# GCP 项目 ID，部分 GCS API（如创建桶）需要此值
GCP_PROJECT_ID=my-gcp-project

# 目标 GCS Bucket 名称（DRY_RUN=false 时必填）
TARGET_BUCKET=my-gcs-bucket

# GCS 访问端点，通常无需修改；用于集成测试时可指向 fake-gcs-server
STORAGE_BASE_URL=https://storage.googleapis.com

# 对象路径前缀，用于测试隔离（如 ci-run-123/），生产环境留空
GCS_PREFIX=

# GCS Service Account JSON 密钥文件路径；留空则使用 ADC（Application Default Credentials）
JSON_KEY=/path/to/service-account.json

# S3 请求重签名用的密钥对（与客户端 SDK 配置一致）
PROXY_AWS_ACCESS_KEY_ID=minioadmin
PROXY_AWS_SECRET_ACCESS_KEY=minioadmin


# -----------------------------------------------------------------------------
# 运行模式
# -----------------------------------------------------------------------------

# DRY_RUN=true 时不发起任何真实 GCS API 调用，适合本地开发和单元测试
# 生产环境必须设置为 false（默认 true，防止意外写入）
DRY_RUN=false

# 开启 DEBUG 级别日志，会输出请求头等敏感信息，仅限本地调试
DEBUG_LOGGING=false


# -----------------------------------------------------------------------------
# HTTP 连接池
# -----------------------------------------------------------------------------

# 代理到 GCS 的 HTTP Transport 最大空闲连接总数（默认 1000）
MAX_IDLE_CONNS=1000

# 单个 Host 的最大空闲连接数（默认 1000）
MAX_IDLE_CONNS_PER_HOST=1000


# =============================================================================
# 请求数据日志系统（Request Data Log）
# =============================================================================
#
# 本系统使用  将每条 HTTP 请求以
# SOH（\u0001）分隔的 CSV 格式异步写入本地文件，供离线分析/审计使用。
#
# 日志格式（固定 8 列）：
#   timestamp_ms \u0001 request_id \u0001 source_ip \u0001 http_method \u0001
#   api_method   \u0001 bucket     \u0001 status_code \u0001 duration_ms
#
# 示例行（\u0001 以可见分隔符展示）：
#   1744597200000|req-AbCd1234|12.34.56.78|GET|GetObject|my-bucket|200|42
#
# 字段说明：
#   timestamp_ms  — 请求进入中间件时的 Unix 毫秒时间戳
#   request_id    — Chi middleware.RequestID 生成或从 X-Request-ID 头继承的 ID
#   source_ip     — 客户端真实 IP，解析优先级：
#                     X-Forwarded-For（取第一个逗号前的值）
#                     → X-Real-Ip
#                     → r.RemoteAddr（去掉端口）
#   http_method   — HTTP 动词，如 GET / PUT / DELETE
#   api_method    — 推断的 S3 操作名，如 GetObject / PutBucketLifecycle
#   bucket        — 从请求路径第一段解析的桶名（path-style）
#   status_code   — HTTP 响应状态码
#   duration_ms   — 从请求进入中间件到响应写完的耗时（毫秒）
#
# 文件命名与轮转：
#   • 路径模板中 %Y/%M/%D 会被替换为当前年/月/日（两位补零）
#   • 每天首次写入时触发日轮转，旧文件重命名为 .1 / .2 …
#   • 文件超过 REQUEST_LOG_MAX_SIZE_MB 时同样触发大小轮转
#   • MaxBackup 控制保留的轮转备份数量（超出部分被 ymlog 覆盖）
#   • StartCleanup goroutine 每天 00:05 额外扫描目录，删除日期早于
#     REQUEST_LOG_KEEP_DAYS 天前的 req_YYYYMMDD.csv(.N) 文件
#
# =============================================================================

# 是否启用请求数据日志（默认 true）
# 设为 false 时跳过 Init() 和中间件注册，零性能开销
REQUEST_LOG_ENABLED=true

# 日志文件路径模板，支持 %Y（年）%M（月）%D（日）占位符
# 目录不存在时会自动创建
# 示例：
#   本地开发  → ./logs/req_%Y%M%D.csv
#   生产 K8s  → /var/log/s3proxy/req_%Y%M%D.csv
REQUEST_LOG_PATH=./logs/req_%Y%M%D.csv

# 单个日志文件的最大体积（MB），超出后触发大小轮转（默认 512）
# 设为 0 则仅按日轮转，不限制大小
REQUEST_LOG_MAX_SIZE_MB=512

# ymlog 保留的轮转备份文件数量（默认 5）
# 超出时最旧的备份被覆盖（.1 → .2 → … → .MaxBackup）
# 注意：这是 ymlog 内部的 rename 机制；最终按天删除由 KEEP_DAYS 控制
REQUEST_LOG_MAX_BACKUP=5

# 异步写入的 channel 缓冲条数（默认 10240）
# 流量高峰时 channel 打满会阻塞请求，建议设置为峰值 QPS × 预估排队时间（秒）
# 例：10000 QPS × 1s 排队 = 10000；保守起见设 10240
REQUEST_LOG_CHAN_BUF=10240

# 日志文件保留天数（默认 7）
# 每天 00:05 自动删除文件名日期早于 N 天前的 req_*.csv 及其轮转备份
# 例：设为 7 表示保留最近 7 天，第 8 天起的旧文件被删除
# 对应参考项目 CleanOldLogs 中的 time.Now().AddDate(0, 0, -N)
REQUEST_LOG_KEEP_DAYS=7
